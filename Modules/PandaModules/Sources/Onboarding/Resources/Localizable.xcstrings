    "Developer Mode" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Developer Mode"
          }
        }
      }
    },
    "Developer Mode disables cloud authentication so third-party apps can connect directly." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Developer Mode deaktiviert die Cloud-Authentifizierung, damit Drittanbieter-Apps direkt verbinden können."
          }
        }
      }
    },
    "Developer Mode lets third-party apps like this one control your printer. It only works when LAN Mode is enabled." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Developer Mode ermöglicht Drittanbieter-Apps wie dieser, deinen Drucker zu steuern. Er funktioniert nur mit aktiviertem LAN Mode."
          }
        }
      }
    },
    "Done" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fertig"
          }
        }
