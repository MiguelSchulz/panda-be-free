    "LAN Mode" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LAN Mode"
          }
        }
      }
    },
    "LAN Mode allows your printer to communicate directly over your local network without going through the cloud." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der LAN Mode ermöglicht deinem Drucker die direkte Kommunikation über dein lokales Netzwerk, ohne den Umweg über die Cloud."
          }
        }
      }
    },
    "Look for the **lock icon** indicating LAN mode" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suche nach dem **Schloss-Symbol**, das den LAN Mode anzeigt"
          }
        }
      }
    },
    "Navigate to **WLAN** (or Network Settings)" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Navigiere zu **WLAN** (oder Netzwerkeinstellungen)"
          }
        }
      }
    },
    "Note down the **IP Address** shown" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notiere dir die angezeigte **IP-Adresse**"
          }
        }
      }
    },
    "Note the **Serial Number** on the Device tab — required for some printers" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notiere die **Seriennummer** im Reiter \u201EGerät\u201C — bei einigen Druckern erforderlich"
