default_platform :ios

PROJECT       = "BambuBeFree.xcodeproj"
SCHEME        = "BambuBeFree"
OUTPUT_DIR    = "build/fastlane"

def bundle_id
  ENV.fetch("APP_BUNDLE_ID", "com.bambubefree.app")
end

def widget_bundle_id
  "#{bundle_id}.widgets"
end

def asc_api_key
  app_store_connect_api_key(
    key_id:       ENV.fetch("ASC_KEY_ID"),
    issuer_id:    ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_FILEPATH"),
    in_house:     false
  )
end

platform :ios do

  # ------------------------------------------------------------------
  # deploy — Build and upload to App Store Connect (TestFlight)
  # ------------------------------------------------------------------
  desc "Build and upload to TestFlight"
  lane :deploy do
    api_key = asc_api_key

    match(
      type:           "appstore",
      app_identifier: [bundle_id, widget_bundle_id],
      api_key:        api_key,
      readonly:       true
    )

    latest = latest_testflight_build_number(
      api_key:        api_key,
      app_identifier: bundle_id
    )
    increment_build_number(
      build_number: latest + 1,
      xcodeproj:    PROJECT
    )

    gym(
      project:          PROJECT,
      scheme:           SCHEME,
      configuration:    "Release",
      clean:            true,
      output_directory: OUTPUT_DIR,
      output_name:      "BambuBeFree",
      export_method:    "app-store",
      export_options: {
        provisioningProfiles: {
          bundle_id        => "match AppStore #{bundle_id}",
          widget_bundle_id => "match AppStore #{widget_bundle_id}"
        },
        signingStyle: "manual",
        teamID:       ENV.fetch("APPLE_TEAM_ID")
      },
      xcargs: "APP_BUNDLE_ID='#{bundle_id}' " \
              "DEVELOPMENT_TEAM='#{ENV.fetch('APPLE_TEAM_ID')}' " \
              "CODE_SIGN_STYLE=Manual"
    )

    upload_to_testflight(
      api_key:        api_key,
      app_identifier: bundle_id,
      ipa:            "#{OUTPUT_DIR}/BambuBeFree.ipa",
      skip_waiting_for_build_processing: true
    )
  end

end
